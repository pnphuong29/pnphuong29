# If a package manager directory is broadly ignored, unignore both the kept
# subdirectory and its descendants so nested workspaces remain trackable.
**/.yarn/*
!**/.yarn/patches
!**/.yarn/patches/**
!**/.yarn/plugins
!**/.yarn/plugins/**
!**/.yarn/releases
!**/.yarn/releases/**
!**/.yarn/sdks
!**/.yarn/sdks/**
!**/.yarn/versions
!**/.yarn/versions/**

